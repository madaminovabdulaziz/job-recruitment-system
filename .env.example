# Copy this file to .env and fill in real values. Never commit .env.

# Django secret key — generate one for production (keep it secret).
SECRET_KEY=django-insecure-change-me-for-production

# Debug: True for local development, False in production.
DEBUG=True

# Comma-separated list of allowed hosts (used when DEBUG=False).
# In production set this to your deployed domain, e.g. myapp.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated HTTPS origins trusted for CSRF (production only).
# e.g. CSRF_TRUSTED_ORIGINS=https://myapp.onrender.com
CSRF_TRUSTED_ORIGINS=

# Database URL. Leave blank to use local SQLite (default).
# For cloud Postgres, e.g.:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
